---
import { cn } from '@/utils/helpers';

interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'white';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  type?: 'button' | 'submit';
  disabled?: boolean;
  external?: boolean;
}

const { 
  variant = 'primary', 
  size = 'md', 
  href, 
  class: className,
  type = 'button',
  disabled = false,
  external = false
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center gap-2 font-semibold rounded-xl transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed';

const variants = {
  primary: 'bg-gradient-brand text-white shadow-brand hover:shadow-brand-lg hover:-translate-y-0.5',
  secondary: 'bg-white text-brand-primary border-2 border-brand-primary hover:bg-brand-primary hover:text-white',
  ghost: 'bg-transparent text-text-primary hover:bg-surface-secondary',
  white: 'bg-white text-brand-primary hover:shadow-brand-lg hover:-translate-y-0.5',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const classes = cn(baseStyles, variants[variant], sizes[size], className);
const externalProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

{href ? (
  <a href={href} class={classes} {...externalProps}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled}>
    <slot />
  </button>
)}

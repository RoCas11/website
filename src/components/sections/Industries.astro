---
import { type Locale, getLocalizedPath } from '@/lib/i18n';

interface Props { locale: Locale; }
const { locale } = Astro.props;

const content = {
  es: {
    label: 'Multi-Vertical', title: 'Una plataforma, múltiples industrias', subtitle: 'Templates pre-configurados por sector. Implementación rápida con flujos adaptados a tu operación.',
    cta: '¿Tu industria no está listada? Creamos templates personalizados.',
    industries: [
      { id: 'bio', name: 'Biorremediación', flow: 'MERE → Biopila → Liberación', tags: ['Ambiental', 'DDJJ', 'Auditoría'] },
      { id: 'oil', name: 'Oil & Gas', flow: 'OT → Inspección → PO', tags: ['Herramientas', 'Servicios', 'Campo'] },
      { id: 'logistics', name: 'Logística', flow: 'Checkpoints → Entrega', tags: ['Cadena frío', 'IoT', 'GPS'] },
      { id: 'manufacturing', name: 'Manufactura', flow: 'Lote → QC → Liberación', tags: ['Calidad', 'Lotes', 'ISO'] },
      { id: 'construction', name: 'Construcción', flow: 'Obra → Certificados', tags: ['Avance', 'Materiales', 'Hitos'] },
      { id: 'health', name: 'Salud', flow: 'Muestra → Resultados', tags: ['Laboratorio', 'ANMAT', 'Cadena'] },
      { id: 'legal', name: 'Legal', flow: 'Expediente → Resolución', tags: ['Evidencia', 'Custodia', 'Firma'] },
      { id: 'software', name: 'Software Dev', flow: 'Reqs → QA → Deploy', tags: ['CI/CD', 'Releases', 'Audit'] }
    ]
  },
  en: {
    label: 'Multi-Vertical', title: 'One platform, multiple industries', subtitle: 'Pre-configured templates by sector. Fast implementation with workflows adapted to your operation.',
    cta: 'Your industry not listed? We create custom templates.',
    industries: [
      { id: 'bio', name: 'Bioremediation', flow: 'MERE → Biopile → Release', tags: ['Environmental', 'Statement', 'Audit'] },
      { id: 'oil', name: 'Oil & Gas', flow: 'WO → Inspection → PO', tags: ['Tools', 'Services', 'Field'] },
      { id: 'logistics', name: 'Logistics', flow: 'Checkpoints → Delivery', tags: ['Cold chain', 'IoT', 'GPS'] },
      { id: 'manufacturing', name: 'Manufacturing', flow: 'Batch → QC → Release', tags: ['Quality', 'Batches', 'ISO'] },
      { id: 'construction', name: 'Construction', flow: 'Site → Certificates', tags: ['Progress', 'Materials', 'Milestones'] },
      { id: 'health', name: 'Healthcare', flow: 'Sample → Results', tags: ['Laboratory', 'FDA', 'Chain'] },
      { id: 'legal', name: 'Legal', flow: 'Case → Resolution', tags: ['Evidence', 'Custody', 'Signature'] },
      { id: 'software', name: 'Software Dev', flow: 'Reqs → QA → Deploy', tags: ['CI/CD', 'Releases', 'Audit'] }
    ]
  },
  pt: {
    label: 'Multi-Vertical', title: 'Uma plataforma, múltiplas indústrias', subtitle: 'Templates pré-configurados por setor. Implementação rápida com fluxos adaptados à sua operação.',
    cta: 'Sua indústria não está listada? Criamos templates personalizados.',
    industries: [
      { id: 'bio', name: 'Biorremediação', flow: 'MERE → Biopilha → Liberação', tags: ['Ambiental', 'Declaração', 'Auditoria'] },
      { id: 'oil', name: 'Oil & Gas', flow: 'OT → Inspeção → PO', tags: ['Ferramentas', 'Serviços', 'Campo'] },
      { id: 'logistics', name: 'Logística', flow: 'Checkpoints → Entrega', tags: ['Cadeia frio', 'IoT', 'GPS'] },
      { id: 'manufacturing', name: 'Manufatura', flow: 'Lote → QC → Liberação', tags: ['Qualidade', 'Lotes', 'ISO'] },
      { id: 'construction', name: 'Construção', flow: 'Obra → Certificados', tags: ['Avanço', 'Materiais', 'Marcos'] },
      { id: 'health', name: 'Saúde', flow: 'Amostra → Resultados', tags: ['Laboratório', 'ANVISA', 'Cadeia'] },
      { id: 'legal', name: 'Legal', flow: 'Processo → Resolução', tags: ['Evidência', 'Custódia', 'Assinatura'] },
      { id: 'software', name: 'Software Dev', flow: 'Reqs → QA → Deploy', tags: ['CI/CD', 'Releases', 'Audit'] }
    ]
  }
};
const t = content[locale];

const colorMap: Record<string, string> = {
  bio: 'from-emerald-500 to-green-600', oil: 'from-blue-800 to-blue-600', logistics: 'from-violet-600 to-purple-500',
  manufacturing: 'from-cyan-600 to-teal-500', construction: 'from-orange-500 to-amber-500', health: 'from-pink-500 to-rose-500',
  legal: 'from-indigo-600 to-violet-500', software: 'from-teal-500 to-cyan-500'
};
---

<section class="section bg-white overflow-hidden" id="industrias">
  <div class="container-custom">
    <div class="section-header">
      <span class="badge-primary mb-4">{t.label}</span>
      <h2 class="section-title">{t.title}</h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {t.industries.map((industry) => (
        <div class="card-hover group">
          <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${colorMap[industry.id]} flex items-center justify-center mb-4 group-hover:scale-110 transition-transform`}>
            {industry.id === 'bio' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>}
            {industry.id === 'oil' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>}
            {industry.id === 'logistics' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>}
            {industry.id === 'manufacturing' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>}
            {industry.id === 'construction' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>}
            {industry.id === 'health' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>}
            {industry.id === 'legal' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>}
            {industry.id === 'software' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>}
          </div>
          <h3 class="font-bold text-text-primary mb-1">{industry.name}</h3>
          <p class="text-sm text-text-tertiary mb-4 font-mono">{industry.flow}</p>
          <div class="flex flex-wrap gap-2">
            {industry.tags.map((tag) => (
              <span class="text-xs px-2 py-1 bg-surface-secondary rounded-full text-text-tertiary">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
    
    <p class="text-center text-text-tertiary mt-8">{t.cta}</p>
  </div>
</section>

---
import { t, type Locale } from '@/lib/i18n';
import Button from '@/components/common/Button.astro';
import navigation from '@content/config/navigation.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

&lt;section class="relative overflow-hidden bg-gradient-hero min-h-[90vh] flex items-center"&gt;
  &lt;div class="absolute inset-0 overflow-hidden"&gt;
    &lt;div class="absolute -top-40 -right-40 w-80 h-80 bg-white/5 rounded-full blur-3xl"&gt;&lt;/div&gt;
    &lt;div class="absolute -bottom-40 -left-40 w-80 h-80 bg-brand-light/10 rounded-full blur-3xl"&gt;&lt;/div&gt;
    &lt;div class="absolute inset-0 opacity-10" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g&gt;%3C/svg%3E&quot;);"&gt;&lt;/div&gt;
  &lt;/div&gt;
  
  &lt;div class="container-custom relative z-10"&gt;
    &lt;div class="grid lg:grid-cols-2 gap-12 items-center"&gt;
      &lt;div class="text-white space-y-8"&gt;
        &lt;div class="space-y-6"&gt;
          &lt;span class="badge-white animate-fade-in"&gt;
            &lt;span class="relative flex h-2 w-2"&gt;
              &lt;span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"&gt;&lt;/span&gt;
              &lt;span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"&gt;&lt;/span&gt;
            &lt;/span&gt;
            {t(locale, 'hero.badge')}
          &lt;/span&gt;
          
          &lt;h1 class="text-display-xl font-extrabold animate-fade-in-up"&gt;{t(locale, 'hero.title')}&lt;/h1&gt;
          &lt;p class="text-xl text-white/80 max-w-xl animate-fade-in-up animate-delay-100"&gt;{t(locale, 'hero.subtitle')}&lt;/p&gt;
        &lt;/div&gt;
        
        &lt;div class="flex flex-wrap gap-4 animate-fade-in-up animate-delay-200"&gt;
          &lt;Button href={navigation.ctaLinks.demo} variant="white" size="lg" external&gt;
            {t(locale, 'hero.cta')}
            &lt;svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"&gt;&lt;path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /&gt;&lt;/svg&gt;
          &lt;/Button&gt;
          &lt;Button href="#como-funciona" variant="ghost" size="lg" class="text-white border-2 border-white/30 hover:bg-white/10"&gt;
            {t(locale, 'hero.ctaSecondary')}
          &lt;/Button&gt;
        &lt;/div&gt;
        
        &lt;div class="flex flex-wrap gap-4 pt-4 animate-fade-in-up animate-delay-300"&gt;
          &lt;div class="flex items-center gap-2 text-sm text-white/80"&gt;
            &lt;svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"&gt;&lt;path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /&gt;&lt;/svg&gt;
            {t(locale, 'features.signature')}
          &lt;/div&gt;
          &lt;div class="flex items-center gap-2 text-sm text-white/80"&gt;
            &lt;svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"&gt;&lt;path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636a9 9 0 010 12.728m0 0l-2.829-2.829m2.829 2.829L21 21M15.536 8.464a5 5 0 010 7.072m0 0l-2.829-2.829m-4.243 2.829a4.978 4.978 0 01-1.414-2.83m-1.414 5.658a9 9 0 01-2.167-9.238m7.824 2.167a1 1 0 111.414 1.414m-1.414-1.414L3 3m8.293 8.293l1.414 1.414" /&gt;&lt;/svg&gt;
            {t(locale, 'features.offline')}
          &lt;/div&gt;
          &lt;div class="flex items-center gap-2 text-sm text-white/80"&gt;
            &lt;svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"&gt;&lt;path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /&gt;&lt;/svg&gt;
            {t(locale, 'features.blockchain')}
          &lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
      
      &lt;div class="hidden lg:block animate-fade-in-up animate-delay-200"&gt;
        &lt;div class="relative"&gt;
          &lt;div class="relative bg-white rounded-3xl shadow-2xl p-6 animate-float"&gt;
            &lt;div class="flex items-center justify-between mb-6"&gt;
              &lt;span class="text-sm font-medium text-text-tertiary"&gt;Pasaporte Digital&lt;/span&gt;
              &lt;span class="flex items-center gap-1.5 text-sm font-semibold text-green-600 bg-green-50 px-3 py-1 rounded-full"&gt;
                &lt;svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"&gt;&lt;path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /&gt;&lt;/svg&gt;
                Verificado
              &lt;/span&gt;
            &lt;/div&gt;
            &lt;div class="mb-6"&gt;
              &lt;div class="text-xs text-text-tertiary mb-1"&gt;ID&lt;/div&gt;
              &lt;div class="font-mono text-lg font-bold text-text-primary"&gt;BP-2024-00847&lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="grid grid-cols-2 gap-4 mb-6"&gt;
              &lt;div&gt;&lt;div class="text-xs text-text-tertiary mb-1"&gt;Vertical&lt;/div&gt;&lt;div class="font-semibold text-text-primary"&gt;Biorremediación&lt;/div&gt;&lt;/div&gt;
              &lt;div&gt;&lt;div class="text-xs text-text-tertiary mb-1"&gt;Eventos&lt;/div&gt;&lt;div class="font-semibold text-text-primary"&gt;12 registrados&lt;/div&gt;&lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="space-y-3 border-t border-gray-100 pt-4"&gt;
              &lt;div class="flex items-center gap-3"&gt;
                &lt;div class="w-8 h-8 rounded-full bg-brand-primary/10 flex items-center justify-center"&gt;&lt;svg class="w-4 h-4 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"&gt;&lt;path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /&gt;&lt;/svg&gt;&lt;/div&gt;
                &lt;div class="flex-1"&gt;&lt;div class="text-sm font-medium text-text-primary"&gt;MERE cargado&lt;/div&gt;&lt;div class="text-xs text-text-tertiary"&gt;Hace 2 horas&lt;/div&gt;&lt;/div&gt;
                &lt;span class="text-xs text-green-600 font-medium"&gt;Firmado&lt;/span&gt;
              &lt;/div&gt;
              &lt;div class="flex items-center gap-3"&gt;
                &lt;div class="w-8 h-8 rounded-full bg-brand-primary/10 flex items-center justify-center"&gt;&lt;svg class="w-4 h-4 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"&gt;&lt;path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /&gt;&lt;path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" /&gt;&lt;/svg&gt;&lt;/div&gt;
                &lt;div class="flex-1"&gt;&lt;div class="text-sm font-medium text-text-primary"&gt;Foto de ingreso&lt;/div&gt;&lt;div class="text-xs text-text-tertiary"&gt;Hace 1 hora&lt;/div&gt;&lt;/div&gt;
                &lt;span class="text-xs text-green-600 font-medium"&gt;Firmado&lt;/span&gt;
              &lt;/div&gt;
            &lt;/div&gt;
          &lt;/div&gt;
          &lt;div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg px-4 py-2 animate-pulse-slow"&gt;&lt;span class="text-sm font-semibold text-brand-primary"&gt;100% Trazable&lt;/span&gt;&lt;/div&gt;
          &lt;div class="absolute -top-4 -right-4 bg-green-500 text-white rounded-xl shadow-lg px-4 py-2"&gt;&lt;span class="text-sm font-semibold"&gt;Audit-Ready&lt;/span&gt;&lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;
  
  &lt;div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce"&gt;
    &lt;a href="#problema" class="text-white/50 hover:text-white transition-colors"&gt;
      &lt;svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"&gt;&lt;path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /&gt;&lt;/svg&gt;
    &lt;/a&gt;
  &lt;/div&gt;
&lt;/section&gt;

---
import { type Locale } from '@/lib/i18n';
import Button from '@/components/common/Button.astro';
import navigation from '@content/config/navigation.json';

interface Props { locale: Locale; }
const { locale } = Astro.props;

const content = {
  es: {
    label: 'La Solución', title: 'Passport Platform', subtitle: 'Una plataforma que convierte cada paso de tus procesos en evidencia verificable e inmutable.',
    solutions: [
      { title: 'Pasaporte Digital', description: 'Cada activo tiene un pasaporte único con toda su historia trazable.', features: ['ID único por entidad', 'Timeline de eventos', 'Fotos y documentos adjuntos'], icon: 'passport' },
      { title: 'Firma Criptográfica', description: 'Cada evento firmado con Ed25519. Imposible de modificar sin detección.', features: ['Keypair por usuario', 'No repudiable', 'DDJJ integrada'], icon: 'signature' },
      { title: 'Audit Bundle', description: 'Exporta toda la evidencia verificable en un paquete listo para auditoría.', features: ['ZIP con todo incluido', 'Verificación offline', 'Blockchain opcional'], icon: 'bundle' }
    ],
    cta: '¿Listo para transformar tu trazabilidad?', ctaButton: 'Agendar demo gratuita'
  },
  en: {
    label: 'The Solution', title: 'Passport Platform', subtitle: 'A platform that turns every step of your processes into verifiable and immutable evidence.',
    solutions: [
      { title: 'Digital Passport', description: 'Each asset has a unique passport with its entire traceable history.', features: ['Unique ID per entity', 'Event timeline', 'Attached photos and documents'], icon: 'passport' },
      { title: 'Cryptographic Signature', description: 'Each event signed with Ed25519. Impossible to modify without detection.', features: ['Keypair per user', 'Non-repudiable', 'Integrated sworn statement'], icon: 'signature' },
      { title: 'Audit Bundle', description: 'Export all verifiable evidence in a package ready for audit.', features: ['ZIP with everything', 'Offline verification', 'Optional blockchain'], icon: 'bundle' }
    ],
    cta: 'Ready to transform your traceability?', ctaButton: 'Book free demo'
  },
  pt: {
    label: 'A Solução', title: 'Passport Platform', subtitle: 'Uma plataforma que transforma cada passo dos seus processos em evidência verificável e imutável.',
    solutions: [
      { title: 'Passaporte Digital', description: 'Cada ativo tem um passaporte único com todo seu histórico rastreável.', features: ['ID único por entidade', 'Timeline de eventos', 'Fotos e documentos anexados'], icon: 'passport' },
      { title: 'Assinatura Criptográfica', description: 'Cada evento assinado com Ed25519. Impossível de modificar sem detecção.', features: ['Keypair por usuário', 'Não repudiável', 'Declaração integrada'], icon: 'signature' },
      { title: 'Audit Bundle', description: 'Exporte toda a evidência verificável em um pacote pronto para auditoria.', features: ['ZIP com tudo incluído', 'Verificação offline', 'Blockchain opcional'], icon: 'bundle' }
    ],
    cta: 'Pronto para transformar sua rastreabilidade?', ctaButton: 'Agendar demo gratuita'
  }
};
const t = content[locale];
---

<section class="section bg-surface-secondary" id="solucion">
  <div class="container-custom">
    <div class="section-header">
      <span class="badge-primary mb-4">{t.label}</span>
      <h2 class="section-title">{t.title}</h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8 mb-16">
      {t.solutions.map((solution, index) => (
        <div class="card-hover group reveal" style={`animation-delay: ${index * 100}ms`}>
          <div class="w-16 h-16 rounded-2xl bg-gradient-brand flex items-center justify-center mb-6 group-hover:scale-110 transition-transform shadow-brand">
            {solution.icon === 'passport' && <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" /></svg>}
            {solution.icon === 'signature' && <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>}
            {solution.icon === 'bundle' && <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" /></svg>}
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-3">{solution.title}</h3>
          <p class="text-text-secondary mb-6">{solution.description}</p>
          <ul class="space-y-2">
            {solution.features.map((feature) => (
              <li class="flex items-center gap-2 text-sm text-text-secondary">
                <svg class="w-5 h-5 text-success flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div class="bg-gradient-brand rounded-3xl p-8 md:p-12 text-center text-white reveal">
      <h3 class="text-2xl md:text-3xl font-bold mb-8">{t.cta}</h3>
      <Button href={navigation.ctaLinks.demo} variant="white" size="lg" external>
        {t.ctaButton}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </Button>
    </div>
  </div>
</section>

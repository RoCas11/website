---
import { t, getLocalizedPath, type Locale } from '@/lib/i18n';
import settings from '@content/config/settings.json';
import navigation from '@content/config/navigation.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentYear = new Date().getFullYear();

const footerSections = [
  { key: 'product', items: navigation.footerNav.product },
  { key: 'company', items: navigation.footerNav.company },
  { key: 'resources', items: navigation.footerNav.resources },
  { key: 'legal', items: navigation.footerNav.legal },
];

const footerLabels: Record&lt;string, Record&lt;string, string&gt;&gt; = {
  es: {
    product: 'Producto', company: 'Empresa', resources: 'Recursos', legal: 'Legal',
    passport: 'Passport Platform', features: 'Funcionalidades', industries: 'Industrias',
    pricing: 'Precios', howItWorks: 'Cómo funciona', about: 'Sobre nosotros', team: 'Equipo',
    blog: 'Blog', contact: 'Contacto', careers: 'Trabaja con nosotros', docs: 'Documentación',
    api: 'API Reference', faq: 'FAQ', useCases: 'Casos de uso', status: 'Status',
    terms: 'Términos de servicio', privacy: 'Política de privacidad', cookies: 'Cookies', security: 'Seguridad'
  },
  en: {
    product: 'Product', company: 'Company', resources: 'Resources', legal: 'Legal',
    passport: 'Passport Platform', features: 'Features', industries: 'Industries',
    pricing: 'Pricing', howItWorks: 'How it works', about: 'About us', team: 'Team',
    blog: 'Blog', contact: 'Contact', careers: 'Careers', docs: 'Documentation',
    api: 'API Reference', faq: 'FAQ', useCases: 'Use Cases', status: 'Status',
    terms: 'Terms of Service', privacy: 'Privacy Policy', cookies: 'Cookies', security: 'Security'
  },
  pt: {
    product: 'Produto', company: 'Empresa', resources: 'Recursos', legal: 'Legal',
    passport: 'Passport Platform', features: 'Funcionalidades', industries: 'Indústrias',
    pricing: 'Preços', howItWorks: 'Como funciona', about: 'Sobre nós', team: 'Equipe',
    blog: 'Blog', contact: 'Contato', careers: 'Trabalhe conosco', docs: 'Documentação',
    api: 'API Reference', faq: 'FAQ', useCases: 'Casos de uso', status: 'Status',
    terms: 'Termos de Serviço', privacy: 'Política de Privacidade', cookies: 'Cookies', security: 'Segurança'
  }
};

function getLabel(key: string): string {
  return footerLabels[locale]?.[key] || footerLabels.es[key] || key;
}
---

&lt;footer class="bg-gray-900 text-white"&gt;
  &lt;div class="container-custom py-16"&gt;
    &lt;div class="grid grid-cols-2 md:grid-cols-6 gap-8 lg:gap-12"&gt;
      &lt;div class="col-span-2"&gt;
        &lt;a href={getLocalizedPath('/', locale)} class="inline-block mb-6"&gt;
          &lt;img src="/images/logos/logo-horizontal-white.png" alt={settings.site.name} class="h-10 w-auto" /&gt;
        &lt;/a&gt;
        &lt;p class="text-gray-400 mb-6 max-w-xs"&gt;
          {t(locale, 'site.tagline')}. {t(locale, 'site.description')}.
        &lt;/p&gt;
        &lt;div class="flex gap-4"&gt;
          {navigation.socialLinks.map((social: any) =&gt; (
            &lt;a href={social.href} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center hover:bg-brand-primary transition-colors" aria-label={social.name}&gt;
              {social.icon === 'linkedin' &amp;&amp; &lt;svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"&gt;&lt;path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/&gt;&lt;/svg&gt;}
              {social.icon === 'twitter' &amp;&amp; &lt;svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"&gt;&lt;path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/&gt;&lt;/svg&gt;}
            &lt;/a&gt;
          ))}
        &lt;/div&gt;
      &lt;/div&gt;
      
      {footerSections.map((section) =&gt; (
        &lt;div&gt;
          &lt;h3 class="font-semibold mb-4 text-white"&gt;{getLabel(section.key)}&lt;/h3&gt;
          &lt;ul class="space-y-3"&gt;
            {section.items.map((item: any) =&gt; (
              &lt;li&gt;&lt;a href={getLocalizedPath(item.href, locale)} class="text-gray-400 hover:text-white transition-colors text-sm"&gt;{getLabel(item.key)}&lt;/a&gt;&lt;/li&gt;
            ))}
          &lt;/ul&gt;
        &lt;/div&gt;
      ))}
    &lt;/div&gt;
    
    &lt;div class="border-t border-gray-800 mt-12 pt-8"&gt;
      &lt;div class="flex flex-col md:flex-row justify-between items-center gap-4"&gt;
        &lt;p class="text-gray-400 text-sm"&gt;© {currentYear} {settings.site.name}. {t(locale, 'footer.rights')}.&lt;/p&gt;
        &lt;div class="flex items-center gap-6 text-sm"&gt;
          &lt;a href={getLocalizedPath('/terminos-condiciones', locale)} class="text-gray-400 hover:text-white transition-colors"&gt;{getLabel('terms')}&lt;/a&gt;
          &lt;a href={getLocalizedPath('/politica-privacidad', locale)} class="text-gray-400 hover:text-white transition-colors"&gt;{getLabel('privacy')}&lt;/a&gt;
          &lt;a href={getLocalizedPath('/cookies', locale)} class="text-gray-400 hover:text-white transition-colors"&gt;{getLabel('cookies')}&lt;/a&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/footer&gt;

---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/common/Button.astro';
import { getLocaleFromPath, type Locale } from '@/lib/i18n';

const locale = getLocaleFromPath(Astro.url.pathname) as Locale;

const content = {
  es: {
    title: 'Nosotros',
    description: 'Conoce al equipo detrás de Block-Builders Tech',
    hero: { label: 'Nuestra Historia', title: 'Construimos el futuro de la trazabilidad', subtitle: 'Somos un equipo de ingenieros, desarrolladores y expertos en blockchain apasionados por resolver el problema de la confianza en los registros empresariales.' },
    mission: { title: 'Nuestra Misión', text: 'Democratizar el acceso a sistemas de trazabilidad verificable, permitiendo que cualquier empresa pueda demostrar con evidencia criptográfica qué pasó, cuándo pasó y quién lo hizo.' },
    values: { title: 'Nuestros Valores', items: [
      { title: 'Transparencia', description: 'Código abierto donde sea posible. Documentación clara. Sin letra chica.' },
      { title: 'Seguridad', description: 'Criptografía de primer nivel. Auditorías externas. Zero-trust por diseño.' },
      { title: 'Simplicidad', description: 'Interfaces intuitivas. Onboarding en días, no meses. Soporte humano.' },
      { title: 'Innovación', description: 'Mejora continua. Escuchamos a nuestros clientes. Iteramos rápido.' }
    ]},
    cta: { title: '¿Quieres ser parte del equipo?', subtitle: 'Estamos creciendo y buscando talento.', button: 'Ver posiciones abiertas' }
  },
  en: {
    title: 'About Us',
    description: 'Meet the team behind Block-Builders Tech',
    hero: { label: 'Our Story', title: 'Building the future of traceability', subtitle: 'We are a team of engineers, developers and blockchain experts passionate about solving the problem of trust in business records.' },
    mission: { title: 'Our Mission', text: 'Democratize access to verifiable traceability systems, enabling any company to prove with cryptographic evidence what happened, when it happened and who did it.' },
    values: { title: 'Our Values', items: [
      { title: 'Transparency', description: 'Open source where possible. Clear documentation. No fine print.' },
      { title: 'Security', description: 'First-class cryptography. External audits. Zero-trust by design.' },
      { title: 'Simplicity', description: 'Intuitive interfaces. Onboarding in days, not months. Human support.' },
      { title: 'Innovation', description: 'Continuous improvement. We listen to our clients. We iterate fast.' }
    ]},
    cta: { title: 'Want to join the team?', subtitle: 'We are growing and looking for talent.', button: 'View open positions' }
  },
  pt: {
    title: 'Sobre Nós',
    description: 'Conheça a equipe por trás da Block-Builders Tech',
    hero: { label: 'Nossa História', title: 'Construindo o futuro da rastreabilidade', subtitle: 'Somos uma equipe de engenheiros, desenvolvedores e especialistas em blockchain apaixonados por resolver o problema da confiança nos registros empresariais.' },
    mission: { title: 'Nossa Missão', text: 'Democratizar o acesso a sistemas de rastreabilidade verificável, permitindo que qualquer empresa possa provar com evidência criptográfica o que aconteceu, quando aconteceu e quem fez.' },
    values: { title: 'Nossos Valores', items: [
      { title: 'Transparência', description: 'Código aberto onde possível. Documentação clara. Sem letras miúdas.' },
      { title: 'Segurança', description: 'Criptografia de primeiro nível. Auditorias externas. Zero-trust por design.' },
      { title: 'Simplicidade', description: 'Interfaces intuitivas. Onboarding em dias, não meses. Suporte humano.' },
      { title: 'Inovação', description: 'Melhoria contínua. Ouvimos nossos clientes. Iteramos rápido.' }
    ]},
    cta: { title: 'Quer fazer parte da equipe?', subtitle: 'Estamos crescendo e buscando talentos.', button: 'Ver posições abertas' }
  }
};

const t = content[locale];
---

<Layout title={t.title} description={t.description}>
  <section class="section bg-gradient-hero text-white">
    <div class="container-custom text-center">
      <span class="badge-white mb-4">{t.hero.label}</span>
      <h1 class="text-display-lg font-bold mb-6">{t.hero.title}</h1>
      <p class="text-xl text-white/80 max-w-3xl mx-auto">{t.hero.subtitle}</p>
    </div>
  </section>
  
  <section class="section bg-white">
    <div class="container-custom max-w-4xl text-center">
      <h2 class="text-display-sm font-bold text-text-primary mb-6">{t.mission.title}</h2>
      <p class="text-xl text-text-secondary leading-relaxed">{t.mission.text}</p>
    </div>
  </section>
  
  <section class="section bg-surface-secondary">
    <div class="container-custom">
      <h2 class="text-display-sm font-bold text-text-primary text-center mb-12">{t.values.title}</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {t.values.items.map((value, index) => (
          <div class="card-hover text-center">
            <div class="w-16 h-16 rounded-2xl bg-gradient-brand flex items-center justify-center mx-auto mb-4 shadow-brand">
              <span class="text-2xl font-bold text-white">{index + 1}</span>
            </div>
            <h3 class="text-xl font-bold text-text-primary mb-2">{value.title}</h3>
            <p class="text-text-secondary">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <section class="section bg-gradient-brand text-white">
    <div class="container-custom text-center">
      <h2 class="text-display-sm font-bold mb-4">{t.cta.title}</h2>
      <p class="text-lg text-white/80 mb-8">{t.cta.subtitle}</p>
      <Button href="/careers" variant="white" size="lg">{t.cta.button}</Button>
    </div>
  </section>
</Layout>
